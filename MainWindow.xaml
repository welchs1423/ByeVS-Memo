<Window x:Class="ByeVS_Memo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ByeVS-Memo" Height="450" Width="800">
    <Grid x:Name="MainGrid"> <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="0" Margin="5,5,5,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Menu x:Name="MainMenu" Grid.Row="0" VerticalAlignment="Center" Background="#F0F0F0">
                <MenuItem x:Name="RecentFilesMenu" Header="최근 파일"/>
            </Menu>
            <StackPanel x:Name="TopPanel" Grid.Row="1" Orientation="Horizontal" Background="#F0F0F0" Margin="0,4,0,0">
                <Button Content="열기" Click="OpenButton_Click" Margin="0,0,5,5" Width="60" Height="25"/>
                <Button Content="저장" Click="SaveButton_Click" Margin="0,0,5,5" Width="60" Height="25"/>
                <Button x:Name="ThemeButton" Content="다크 모드" Click="ThemeButton_Click" Margin="0,0,0,5" Width="100" Height="25"/>
            </StackPanel>
        </Grid>

        <TextBox x:Name="MainTextBox" Grid.Row="1"
            AcceptsReturn="True"
            AcceptsTab="True"
            VerticalScrollBarVisibility="Auto"
            FontSize="15" Padding="10" BorderThickness="0" />
        </Grid>
    </Window>